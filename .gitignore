## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/
out/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# Rider
.idea/

# DotCover
*.dotCover

# Resharper
_ReSharper*/
*.DotSettings.user

# NuGet
*.nupkg
# Packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if necessary
#!**/packages/repositories.config

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Dotnet Core
project.lock.json
project.fragment.lock.json
artifacts/

# Visual Studio cache files
*.cache
*.ilk
*.log
*.tlog
*.vspscc

# Others
*.DS_Store
Thumbs.db