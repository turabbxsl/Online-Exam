@using OnlineExam.Shared.Commons.Exam.Dtos.API
@model IEnumerable<LeaderboardDto>

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-white border-0 fw-bold">
        <i class="bi bi-trophy-fill text-warning"></i> TOP 10 Liderlər
    </div>
    <ul class="list-group list-group-flush">
        @foreach (var (item, index) in Model.Select((value, i) => (value, i + 1)))
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>@index. @item.username</span>
                <span class="badge bg-primary rounded-pill">@item.score</span>
            </li>
        }
    </ul>
</div>