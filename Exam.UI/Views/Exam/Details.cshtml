@model ExamVM

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container mt-5">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h5 class="fw-bold text-primary mb-1">
                    <i class="bi bi-journal-check me-2"></i> İmtahan Sessiyası
                </h5>

                <div class="d-flex align-items-center gap-2 mt-2">

                    <span class="badge bg-light text-dark border px-3 py-2">
                        <i class="bi bi-person-fill text-primary me-1"></i>
                        <strong>Tələbə:</strong> @Model.Username
                    </span>

                    <span class="text-muted small">
                        <i class="bi bi-hash"></i> Sessiya ID: @Model.ExamId
                    </span>

                </div>
            </div>

            <div id="statusIndicator">
                <span class="badge bg-success px-3 py-2 fs-6" id="badgeStatus">
                    <i class="bi bi-clock-history me-1"></i>
                    Davam edir
                </span>
            </div>

        </div>
    </div>

    <div id="examContent">
        <form id="questionsForm">
            <input type="hidden" id="examId" value="@Model.ExamId" />

            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                <div class="card mb-3 shadow-sm question-card">
                    <div class="card-header bg-light">
                        <strong>Sual @(i + 1)</strong>
                    </div>
                    <div class="card-body">
                        <p class="card-text fs-5">@Model.Questions[i].Content</p>

                        <div class="options-group">
                            @foreach (var option in Model.Questions[i].Options)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio"
                                           name="answer_@Model.Questions[i].Id"
                                           id="opt_@option.Id"
                                           value="@option.Id" required>
                                    <label class="form-check-label" for="opt_@option.Id">
                                        @option.OptionText
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 mb-5">
                <button type="button" id="btnSubmit" class="btn btn-primary btn-lg px-5">İmtahanı Tamamla</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        const examId = document.getElementById("examId").value;
        const statusBadge = document.getElementById("badgeStatus");
        const examContent = document.getElementById("examContent");

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("https://localhost:7199/examHub")
            .withAutomaticReconnect()
            .build();

        async function startSignalR() {
            try {
                await connection.start();
                console.log("SignalR: Bağlantı uğurla quruldu.");
                await connection.invoke("JoinToExamGroup", examId);
            } catch (err) {
                console.error("SignalR Xətası: ", err);
                setTimeout(startSignalR, 5000);
            }
        }

        connection.on("ReceiveExamStatus", (data) => {
            console.log("Serverdən mesaj gəldi:", data);

            if (data.status === "Finished") {
                handleExamFinish(data.message);
            }
        });

        function handleExamFinish(msg) {
            statusBadge.className = "badge bg-danger p-2";
            statusBadge.innerText = "Status: Vaxt Bitdi";

            examContent.innerHTML = `
                <div class="alert alert-danger text-center shadow p-5 mt-4">
                    <i class="bi bi-exclamation-triangle-fill display-1"></i>
                    <h2 class="mt-3">İmtahan Tamamlandı!</h2>
                    <p class="lead">${msg}</p>
                    <hr>
                    <p>Cavablarınız avtomatik qeydə alındı (və ya vaxt bitdiyi üçün ləğv edildi).</p>
                    <a href="/" class="btn btn-outline-danger mt-3">Ana Səhifəyə Qayıt</a>
                </div>
            `;

            alert("DİQQƏT: " + msg);
        }

        startSignalR();
    </script>
}