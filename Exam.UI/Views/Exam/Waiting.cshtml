@model Guid

<div class="text-center mt-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <h3 class="mt-3">İmtahan sualları hazırlanır...</h3>
    <p>Zəhmət olmasa, gözləyin. Səhifə bir neçə saniyəyə yenilənəcək.</p>
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            window.location.href = '@Url.Action("Details", new { examId = Model })';
        }, 2000);
    </script>
}